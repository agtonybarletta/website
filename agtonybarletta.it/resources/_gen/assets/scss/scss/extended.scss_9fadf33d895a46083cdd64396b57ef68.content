.project-list {
  flex-wrap: wrap;
  margin-bottom: 1em; }

.project-title {
  flex: 1;
  text-align: right; }

.project-description {
  flex: 2;
  margin-top: 0;
  margin-left: 2em; }
  .project-description p {
    margin-top: 0; }

.break {
  width: 100%; }

img {
  display: block;
  margin-left: auto;
  margin-right: auto; }

.model-viewer {
  border: 2px solid white;
  width: 50vw;
  height: 50vw;
  background-color: #001484;
  margin-left: auto;
  margin-right: auto; }
  @media screen and (max-width: 900px) {
    .model-viewer {
      width: 90vw;
      height: 90vw; } }

